{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "spacetime-start",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoLogo",
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"cd .\\src; spacetime start"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"type": "npm",
			"script": "spacetime:generate",
			"group": "build",
			"problemMatcher": [],
			"label": "spacetime: generate",
			"detail": "Generate spacetime client code."
		},
		{
			"type": "npm",
			"script": "spacetime:publish",
			"group": "build",
			"problemMatcher": [],
			"label": "spacetime: publish",
			"detail": "Publish spacetime schema."
		},
		{
			"type": "npm",
			"script": "build",
			"group": "build",
			"problemMatcher": [],
			"label": "npm: build",
			"detail": "vue-tsc -b && vite build"
		},
		{
			"label": "npm: engine",
			"type": "npm",
			"script": "engine",
			"group": "build",
			"detail": "Starts AI Game Engine Express server (same as engine-start)."
		},
		{
			"label": "assistant: sync",
			"type": "npm",
			"script": "assistants:sync",
			"group": "build",
			"detail": "Sync OpenAI Assistants from local definitions to OpenAI."
		},
		{
			"label": "assistant: dry",
			"type": "npm",
			"script": "assistants:sync:dry",
			"group": "build",
			"detail": "Sync OpenAI Assistants from local definitions to OpenAI."
		}
	]
}